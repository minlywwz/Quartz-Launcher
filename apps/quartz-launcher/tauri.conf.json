{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quartz Launcher",
  "version": "0.1.0",
  "identifier": "com.quartz.launcher",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../quartz-ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix ../quartz-ui",
    "frontendDist": "../quartz-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Minecraft Launcher",
        "width": 520,
        "height": 680,
        "minWidth": 480,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
